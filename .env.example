# Cloudflare Tunnel 토큰
# https://one.dash.cloudflare.com > Zero Trust > Networks > Tunnels 에서 생성
CLOUDFLARE_TUNNEL_TOKEN=

# Notion API
# https://www.notion.so/my-integrations 에서 인테그레이션 생성 후 발급
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 각 DB 페이지 URL에서 추출한 32자리 hex ID
NOTION_WORKOUT_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_EXERCISE_LOG_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# PostgreSQL 연결 (notion_migration.py, FastAPI 백엔드)
# 형식: postgresql://유저:비밀번호@호스트:포트/DB명
DATABASE_URL=postgresql://user:password@localhost:5432/fit
